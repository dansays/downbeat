# Discogs — used to seed your taste rubric from your record collection.
# Username is your Discogs handle. Token is a personal access token from:
#   https://www.discogs.com/settings/developers
DISCOGS_USERNAME=
DISCOGS_TOKEN=

# Last.fm — free API key, powers the "listen ahead" Apple Music song list (/sync-playlist).
# Get one at https://www.last.fm/api/account/create
LASTFM_API_KEY=

# --- /dj-show (Roon) -------------------------------------------------------
# Queues a curated show of upcoming matched artists into a Roon zone. Roon must be on the same
# network and the "Downbeat DJ" extension enabled once under Roon → Settings → Extensions.
# (Roon's API can't create a saved playlist, so the show is loaded into a zone's play queue.)

# Zone the show is queued into — display name or zone id (find names with `roon:zones`).
# If unset and the Core has one zone, that zone is used; otherwise pass --zone.
ROON_ZONE=

# Label recorded on the manifest (default: "Downbeat Radio").
ROON_PLAYLIST_NAME=

# Optional: where the paired-core token is cached (default: data/.roon-state).
# ROON_STATE_DIR=

# --- DJ commentary (ElevenLabs) --------------------------------------------
# Voices Stephen Holloway's intros/outros between songs.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=XFQFwy8OEb9lvFQIMZ5a    # default "Boe Deepman"
# ELEVENLABS_MODEL=eleven_multilingual_v2   # optional override
# ELEVENLABS_SPEED=0.85                      # voice speed 0.7–1.2; <1 = slower/moodier (default 0.85)
# ELEVENLABS_STABILITY=0.5                   # voice stability 0–1; higher = less accent drift (default 0.5; try 0.7 if it still wanders)
# ELEVENLABS_SIMILARITY=0.85                 # similarity_boost 0–1; higher anchors the native accent (default 0.85)
# DJ_CLIP_TAIL_PAD_SEC=0.75                  # silence appended to each clip so the last word isn't clipped (0 disables)

# Folder DJ clip MP3s are written to. MUST be (or map to) a Roon-watched Storage folder so the
# clips can be queued. On a separate machine, point this at a mounted share to that folder.
ROON_DJ_CLIPS_DIR=

# --- Show calendar (ics:build) ---------------------------------------------
# Public base URL the calendar is served from (no trailing slash). Used for the subscribe links
# and per-event UID domain. Defaults to the GitHub Pages URL for this repo.
# CALENDAR_BASE_URL=https://dansays.github.io/downbeat
